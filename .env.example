# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/collab_editor"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (optional)
GITHUB_ID=""
GITHUB_SECRET=""

# Groq (free tier — get a key at https://console.groq.com/)
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# WebSocket
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# WebSocket horizontal scaling (optional — enables Redis adapter in server.ts)
# REDIS_URL="redis://localhost:6379"

# PostgreSQL RLS (enable in production after npm run db:rls)
DATABASE_RLS_ENABLED="false"
# DATABASE_RLS_ROLE="collab_app"

# Integration tests (requires running Postgres + db:push + db:rls)
# RUN_INTEGRATION="true"

# Server
PORT=3000
NODE_ENV=development
